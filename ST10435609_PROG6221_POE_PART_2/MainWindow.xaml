<Window x:Class="ST10435609_PROG6221_POE_PART_2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ST10435609_PROG6221_POE_PART_2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
   
    <Grid>
        <!-- start of the grid -->
        
    <!-- grid for logo -->
        <Grid
            x:Name="logo_grid"
            Visibility="Visible"
            >  <!-- start of logo grid --> 
            
            
            <!-- image logo display -->
            <Image Source= "/logo.jpg" 
                   Height="200"
                   Width="300"
                   Margin="0,0,0,250"
                   />
            
            <!-- button to start AI -->
            <Button 
                    Content="Start AI" 
                    Height="30" 
                    Width="100" 
                    Margin="0,250,0,100" 
                
                    Click="start_ai"
                    />

        </Grid> <!-- end of logo grid -->

        <Grid
            x:Name="username_grid"
            Visibility="Hidden"
            ><!-- start of username grid -->
            
            <!-- TextBox to prompt user -->
            <TextBox 
                x:Name="user_name"
                Height="30"
                Width="200"
                />
            
            <!-- button to submit username -->
            <Button
                Content="Submit"
                Height="30"
                Width="100"
                Margin="0,150,0,50"
                
                Click="submit_name"
                />

        </Grid><!-- end of username grid -->

        <!-- Chat grid -->
        <Grid
            x:Name="chats_grid"
            Visibility="Hidden"
            >
            <!-- start of chats grid -->

           <!-- list view to add chats -->
            <ListView  
                x:Name="chats_list"
                Height="200"
                Width="600"
                Margin="0,0,0,160"
                />
            
            <!-- TextBox for user input -->
            <TextBox 
                x:Name="user_input"
                Height="50"
                Width="300"
                Margin="0,200,0,0"
                />

            <!-- Button to send message -->
            <Button
                Content="submit"
                Height="30"
                Width="100"
                Margin="0,350,0,0"
                
                Click="send_question"
                />

        </Grid><!-- end of chats grid -->

    </Grid><!-- end of parent grid -->
    
</Window>
